@base_address = http://localhost:5000/api/Tasks
@auth_base = http://localhost:5000/api/auth
@token = 

#########################################
### AUTHENTICATION
#########################################

### Register (returns token)
POST {{auth_base}}/register
Content-Type: application/json

{
  "username": "john",
  "email": "mc@gmail.com",
  "password": "password"
}

###

### Login (returns token)
POST {{auth_base}}/login
Content-Type: application/json

{
  "email": "mc@gmail.com",
  "password": "password"
}

# 👆 Copy the token from response and paste below:
 @token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..orwi3K30vhx-IIQXIZMr8ILXNdWWBocCt9msYqtyrVQ

###

#########################################
### TASK ENDPOINTS (Require JWT)
#########################################

### Get All Tasks (requires auth)
GET {{base_address}}
Authorization: Bearer {{token}}

###

### Create Task (requires auth)
POST {{base_address}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "task for admin notice",
  "description": "Created with JWT",
  "dueDate": "2024-08-10T10:00:00Z",
  "isCompleted": false,
  "priority": "High"
}

###

### Soft Delete Task
DELETE {{base_address}}/3
Authorization: Bearer {{token}}

###

### Get Deleted Tasks (trash)
GET {{base_address}}/deleted
Authorization: Bearer {{token}}

###

### Restore Task
POST {{base_address}}/3/restore
Authorization: Bearer {{token}}

###

### Permanent Delete
DELETE {{base_address}}/3/permanent
Authorization: Bearer {{token}}

###

### Test without token (should fail with 401)
GET {{base_address}}